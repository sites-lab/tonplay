rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users — open access (Telegram ID acts as identity)
    match /users/{userId} {
      allow read, write: if true;
      // Deposits subcollection under each user (frontend writes here)
      match /deposits/{depositId} {
        allow read, write: if true;
      }
    }
    // Root-level deposits (Cloud Function writes here)
    match /deposits/{depositId} {
      allow read, write: if true;
    }
    // Withdrawals — anyone can submit, only authenticated admin can read/update
    match /withdrawals/{docId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }
    // Deposit notifications / pending payment tracking
    match /depositNotifications/{docId} {
      allow create: if true;
      allow read, update: if true;
    }
    // Pending payments (Cloud Function reads and updates these)
    match /pendingPayments/{docId} {
      allow read, write: if true;
    }
    // Support messages — users can write their own, anyone can read, admin writes replies
    match /supportMessages/{docId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null;
    }
    // Support threads (for tracking open/replied status)
    match /supportThreads/{docId} {
      allow read, write: if true;
    }
    // Admin reply states (used by Cloud Function for Telegram reply flow)
    match /adminReplyStates/{docId} {
      allow read, write: if true;
    }
    // Global settings — anyone reads, only admin writes
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
